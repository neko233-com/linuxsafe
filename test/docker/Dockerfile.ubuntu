FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    golang-go \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download 2>/dev/null || true

COPY . .

RUN go build -o linuxsafe .

COPY test/fixtures /tmp/test-fixtures

CMD ["./test/docker/run-tests.sh"]
